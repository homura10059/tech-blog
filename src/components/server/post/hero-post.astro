---
import HeroImage from '../../client/image/hero-image'

interface Props {
  title: string
  coverImage: {
    url: string
    aspectRatio?: string
  }
  date: string
  description: string
  slug: string
}
const { title, coverImage, date, description, slug } = Astro.props
---
<section class="p-2">
  <h2 class="m-2 text-5xl font-bold leading-tight tracking-tighter md:text-7xl">
    Latest Post
  </h2>
  <a href={`/posts/${slug}`}>
    <HeroImage
      title={title}
      coverImage={coverImage}
      date={date}
      description={description}
      client:load
    />
  </a>
</section>
