---
import type { PostData } from '../../../domain/posts'
import PostPreview from './post-preview.astro'

interface Props {
  posts: PostData[]
  postsOnly?: boolean
}
const { posts, postsOnly } = Astro.props
---
<section>
  {!postsOnly && (
    <h2 class="mb-8 text-5xl font-bold leading-tight tracking-tighter md:text-7xl">
      More Posts
    </h2>
  )}
  <div class="mb-32 grid grid-cols-1 gap-y-20 md:grid-cols-2 md:gap-x-16 md:gap-y-32 lg:gap-x-32">
    {posts.map(post => (
      <PostPreview
        title={post.title}
        coverImage={post.coverImage}
        date={post.date}
        slug={post.slug}
        excerpt={post.excerpt}
      />
    ))}
  </div>
</section>
