---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/client/navigation/header'
import Footer from '../../components/server/layout/footer.astro'
import Container from '../../components/server/headless/container.astro'
import PageTitle from '../../components/server/headless/Heading/page-title.astro'
import SectionTitle from '../../components/server/headless/Heading/section-title.astro'
---

<Layout title="About">
  <Header client:load />
  <Container>
    <div class="mx-auto mt-4 max-w-2xl">
      <PageTitle>このブログについて</PageTitle>
      <SectionTitle>概要</SectionTitle>
      <p>
        このブログは個人の見解に基づいて書かれており、所属する会社、組織とは全く関係ありません
      </p>
      <SectionTitle>技術スタック</SectionTitle>
      <p>
        <a
          href="https://astro.build"
          class="link mr-1"
          target="_blank"
          rel="noopener noreferrer"
        >
          Astro
        </a>
        & TypeScript & tailwindcss を使って作られています
      </p>
      <SectionTitle>リンク</SectionTitle>
      <ul class="list-inside list-disc">
        <li>
          <a href="/about/privacy_policy" class="link">Privacy Policy</a>
        </li>
        <li>
          <a href="/about/disclaimer" class="link">Disclaimer</a>
        </li>
      </ul>
    </div>
  </Container>
  <Footer />
</Layout>
