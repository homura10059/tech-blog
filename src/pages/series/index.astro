---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/client/navigation/header'
import Footer from '../../components/server/layout/footer.astro'
import Container from '../../components/server/headless/container.astro'
import { getAllSeries } from '../../domain/series'

const allSeries = await getAllSeries()
---

<Layout title="All Series">
  <Header client:load />
  <Container>
    <section class="flex flex-col items-center pb-16 pt-8 md:flex-row md:justify-between md:pb-6">
      <h1 class="mb-6 text-5xl font-bold leading-tight tracking-tighter md:pr-8 md:text-8xl">
        All Series
      </h1>
    </section>
    <div class="mb-6">
      {allSeries.map(({ hash, title }) => (
        <div class="mb-6 text-primary-dark hover:underline">
          <a href={`/series/${hash}`}>{title}</a>
        </div>
      ))}
    </div>
  </Container>
  <Footer />
</Layout>
